# ============================================================
# BanterBox Discord Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Only DISCORD_* and OPENAI_API_KEY are strictly required.

# ============================================================
# DISCORD BOT — REQUIRED
# Get all three from: https://discord.com/developers/applications
# ============================================================
DISCORD_APPLICATION_ID=your_discord_application_id
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_PUBLIC_KEY=your_discord_public_key

# ============================================================
# OPENAI — REQUIRED
# Used for: GPT text generation, Whisper STT (fallback), TTS (fallback)
# Get from: https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================
# ELEVENLABS — OPTIONAL (but recommended)
# Unlocks: Scribe STT (higher accuracy) + higher-quality TTS voices
# Without this key, the bot falls back to Whisper STT + OpenAI TTS.
# Get from: https://elevenlabs.io/
# ============================================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_preferred_voice_id
STT_PROVIDER=whisper
STT_LANGUAGE=auto

# ============================================================
# DATABASE — OPTIONAL
# Supabase (or any PostgreSQL). If not set, bot runs in-memory only.
# Get your Supabase connection string from: https://supabase.com/
# Format: postgresql://postgres:[password]@[host]:5432/postgres
# ============================================================
DATABASE_URL=

# ============================================================
# BOT BEHAVIOUR — OPTIONAL (all have sensible defaults)
# ============================================================
DEFAULT_WAKE_WORD=hey banter
DEFAULT_PERSONALITY=default
DEFAULT_COOLDOWN_SECONDS=30
MAX_DAILY_BANTERS_PER_GUILD=100
MAX_BANTER_WORDS=25

# ============================================================
# SERVER — OPTIONAL
# ============================================================
PORT=5000
NODE_ENV=development

# ============================================================
# DEPLOYMENT NOTES
# ============================================================
# 1. ffmpeg must be installed on the host for voice receive (STT).
#    - Railway/Render: add a Dockerfile or Nixpacks config with ffmpeg.
#    - Local: `choco install ffmpeg` (Windows) or `brew install ffmpeg` (Mac).
# 2. Leave Discord Interactions Endpoint URL blank in the Developer Portal.
#    BanterBox receives slash commands through the Discord Gateway.
# 3. Bot requires these Gateway Intents: Guilds, GuildMessages,
#    GuildVoiceStates, MessageContent.
